     obj.draggedWindow = window
     obj.initialWindowFrame = window:frame()
     obj.initialMousePos = mousePos
+    obj.lastAppliedFrame = nil
     obj.lastFrameUpdateTime = 0  -- Reset throttle on engage
 
+    -- Choose the nearest corner as resize anchor for true corner-style
+    -- 2D resizing behavior (width + height together).
+    local frame = obj.initialWindowFrame
+    local corners = {
+        { x = frame.x, y = frame.y, anchorX = "left", anchorY = "top", name = "top-left" },
+        { x = frame.x + frame.w, y = frame.y, anchorX = "right", anchorY = "top", name = "top-right" },
+        { x = frame.x, y = frame.y + frame.h, anchorX = "left", anchorY = "bottom", name = "bottom-left" },
+        { x = frame.x + frame.w, y = frame.y + frame.h, anchorX = "right", anchorY = "bottom", name = "bottom-right" }
+    }
+
+    local nearestCorner = corners[1]
+    local nearestDistance = math.huge
+    for _, corner in ipairs(corners) do
+        local dx = mousePos.x - corner.x
+        local dy = mousePos.y - corner.y
+        local distance = (dx * dx) + (dy * dy)
+        if distance < nearestDistance then
+            nearestDistance = distance
+            nearestCorner = corner
+        end
+    end
+
+    obj.resizeAnchorX = nearestCorner.anchorX
+    obj.resizeAnchorY = nearestCorner.anchorY
+
     -- Disable animations once at engage (not on every frame)
